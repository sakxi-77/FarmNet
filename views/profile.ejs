<!DOCTYPE html>
<html>

<head>

    <title>Profile</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:#f5f5f5;
        }

        /* NAVBAR */

        .navbar{
            background:#008000;
            padding:18px 50px;
            display:flex;
            justify-content:space-between;
            align-items:center;
        }

        .logo{
            color:white;
            font-size:22px;
            font-weight:bold;
            letter-spacing:1px;
        }

        .nav-links a{
            color:white;
            text-decoration:none;
            margin-left:25px;
            font-size:15px;
            font-weight:500;
            transition:0.3s;
        }

        .nav-links a:hover{
            opacity:0.8;
        }

        /* MAIN SECTION */

        .main{
            width:90%;
            margin:40px auto;
            display:flex;
            gap:35px;
        }

        .left{
            flex:3;
        }

        .right{
            flex:1;
        }

        .welcome{
            font-size:30px;
            color:#1b5e20;
            margin-bottom:25px;
            font-weight:600;
        }

        /* PROFILE CARD */

        .profile-card{
            background:white;
            padding:35px;
            border-radius:15px;
            box-shadow:0 4px 15px rgba(0,0,0,0.08);
        }

        .section-title{
            font-size:30px;
            color:#333;
            margin-bottom:30px;
            font-weight:600;
        }

        .info{
            margin:18px 0;
            font-size:18px;
            color:#333;
            line-height:1.8;
        }

        .label{
            font-weight:bold;
            color:#2e7d32;
        }

        /* BUTTONS */

        .btns{
            margin-top:35px;
        }

        .post-btn{
            display:inline-block;
            background:#1b5e20;
            color:white;
            padding:12px 24px;
            border-radius:8px;
            text-decoration:none;
            font-size:15px;
            margin-right:12px;
            transition:0.3s;
        }

        .post-btn:hover{
            background:#2e7d32;
        }

        /* SIDEBAR */

        .side-card{
            background:white;
            padding:25px;
            border-radius:15px;
            box-shadow:0 4px 15px rgba(0,0,0,0.08);
        }

        .side-card h2{
            color:#1b5e20;
            margin-bottom:20px;
            font-size:24px;
        }

        .side-card p{
            font-size:16px;
            margin:18px 0;
            color:#555;
        }

        /* MOBILE */

        @media(max-width:900px){

            .main{
                flex-direction:column;
            }

            .navbar{
                flex-direction:column;
                gap:15px;
            }

            .nav-links a{
                margin:0 10px;
            }

        }

    </style>

</head>

<body>

    <!-- NAVBAR -->

    <div class="navbar">

        <div class="logo">
            FARMNET
        </div>

        <div class="nav-links">

            <a href="/">Home</a>

            <a href="/blog">Discussion</a>

            <a href="/myblog">My Posts</a>

            <a href="/logout">Logout</a>

        </div>

    </div>

    <!-- MAIN -->

    <div class="main">

        <!-- LEFT SECTION -->

        <div class="left">

            <div class="welcome">
                Hello <%= user.fname %> 
            </div>

            <div class="profile-card">

                <div class="section-title">
                    My Profile
                </div>

                <div class="info">
                    <span class="label">Name:</span>
                    <%= user.fname %>
                </div>

                <div class="info">
                    <span class="label">Aadhar:</span>
                    <%= user.aadhar %>
                </div>

                <div class="info">
                    <span class="label">Mobile:</span>
                    <%= user.mobile || "Not Added" %>
                </div>

                <div class="info">
                    <span class="label">Village:</span>
                    <%= user.village || "Not Added" %>
                </div>

                <div class="btns">

                    <a href="/myblog" class="post-btn">
                         My Posts
                    </a>

                    <a href="/newInnovation" class="post-btn">
                         New Post
                    </a>

                </div>

            </div>

        </div>

        <!-- RIGHT SECTION -->

        <div class="right">

            <div class="side-card">

                <h2>🌱 Farmer Dashboard</h2>

                <p>✔ Manage your farming posts</p>

                <p>✔ Share innovations with farmers</p>

                <p>✔ Connect with agriculture community</p>

                <p>✔ Explore modern farming ideas</p>

                <p>✔ Improve crop productivity</p>

            </div>

        </div>

    </div>

</body>

</html>