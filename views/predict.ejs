<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>FarmNet - Crop Prediction</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;

    background:
    linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)),
    url('https://images.unsplash.com/photo-1500937386664-56d1dfef3854?q=80&w=1974&auto=format&fit=crop');

    background-size:cover;
    background-position:center;
    background-attachment:fixed;

    min-height:100vh;
}

/* NAVBAR */

.navbar{
    width:100%;
    background:#008000;
    padding:20px 60px;

    display:flex;
    justify-content:space-between;
    align-items:center;

    position:sticky;
    top:0;
    z-index:1000;
}

.logo{
    color:white;
    font-size:30px;
    font-weight:bold;
}

.nav-links a{
    color:white;
    text-decoration:none;
    margin-left:28px;
    font-size:16x;
    transition:0.3s;
}

.nav-links a:hover{
    color:#d4ff7f;
}

/* MAIN */

.main-container{
    width:90%;
    margin:50px auto;

    display:flex;
    gap:35px;
    justify-content:center;
    align-items:flex-start;
    flex-wrap:wrap;
}

/* CARDS */

.input-section,
.result-section{

    flex:1;
    min-width:420px;

    background:rgba(255,255,255,0.12);
    backdrop-filter:blur(12px);

    border:1px solid rgba(255,255,255,0.2);

    border-radius:25px;

    padding:40px;

    box-shadow:0 8px 35px rgba(0,0,0,0.3);

    color:white;
}

h2{
    text-align:center;
    margin-bottom:25px;
    font-size:24px;
    color:#d4ff7f;
}

/* FORM */

label{
    display:block;
    margin-top:18px;
    margin-bottom:8px;

    font-size:20px;
    font-weight:bold;
}

input,
select{
    width:100%;
    padding:15px;

    border:none;
    border-radius:12px;

    font-size:16px;

    outline:none;
}

input:focus,
select:focus{
    border:2px solid #7fff00;
}

/* BUTTONS */

.btn-group{
    display:flex;
    gap:20px;
    margin-top:30px;
}

button{
    flex:1;

    padding:15px;
    border:none;
    border-radius:10px;

    font-size:18px;
    font-weight:bold;

    cursor:pointer;
    transition:0.3s;
}

.predict-btn{
    background:#00a000;
    color:white;
}

.clear-btn{
    background:#1f1f1f;
    color:white;
}

button:hover{
    transform:translateY(-2px);
    opacity:0.9;
}

/* RESULT CARD */

.result-card{

    background:rgba(255,255,255,0.15);

    padding:30px;
    border-radius:20px;

    margin-top:20px;
}

.result-card h1{
    text-align:center;
    color:#d4ff7f;
    margin-bottom:25px;
    font-size:42px;
}

.analysis p{
    margin:12px 0;
    font-size:18px;
    line-height:1.7;
}

.analysis hr{
    margin:20px 0;
    border:1px solid rgba(255,255,255,0.2);
}

/* EMPTY BOX */

.empty-box{
    text-align:center;
    margin-top:120px;

    color:#ddd;
    font-size:28px;
}

/* RAINFALL */

#rainfallValue{
    margin-top:10px;
    font-size:17px;
}

/* FOOTER */

.footer{
    margin-top:60px;
    background:#111;
    color:white;

    text-align:center;

    padding:25px;
}

.footer p{
    margin:8px 0;
    font-size:18px;
}

/* MOBILE */

@media(max-width:900px){

    .main-container{
        flex-direction:column;
    }

    .navbar{
        flex-direction:column;
        gap:15px;
    }

    .nav-links a{
        margin:0 10px;
        font-size:18px;
    }

    .logo{
        font-size:34px;
    }

}

</style>

<script type="text/javascript">
function googleTranslateElementInit() {
    new google.translate.TranslateElement(
        {
            pageLanguage: 'en',
            includedLanguages: 'en,mr,hi'
        },
        'google_translate_element'
    );
}
</script>

<script type="text/javascript"
src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit">
</script>

</head>

<body>

<!-- NAVBAR -->

<div class="navbar">

    <div class="logo">FARMNET</div>

    <div class="nav-links">

        <a href="/">Home</a>
        <a href="/blog">Discussion</a>

    </div>

</div>

<!-- MAIN -->

<div class="main-container">

    <!-- LEFT -->

    <div class="input-section">

        <h2>Crop Prediction</h2>

        <form id="predictionForm">

            <label>Nitrogen (N)</label>

            <select id="N_select" required>
                <option value="">Select Nitrogen</option>
                <option>20</option>
                <option>40</option>
                <option>60</option>
                <option>80</option>
                <option>100</option>
            </select>
            <p style="margin:8px 0; color:#ddd;">
            OR enter custom value
            </p>
            
            <input
            type="number"
            id="N"
            placeholder="Custom Nitrogen value">

            <label>Phosphorus (P)</label>

            <select id="P_select" required>
                <option value="">Select Phosphorus</option>
                <option>20</option>
                <option>40</option>
                <option>60</option>
                <option>80</option>
                <option>100</option>
            </select>
            <p style="margin:8px 0; color:#ddd;">
            OR enter custom value
            </p>
            
            <input
            type="number"
            id="P"
            placeholder="Custom Phosphorus value">

            <label>Potassium (K)</label>

            <select id="K_select" required>
                <option value="">Select Potassium</option>
                <option>20</option>
                <option>40</option>
                <option>60</option>
                <option>80</option>
                <option>100</option>
            </select>
            <p style="margin:8px 0; color:#ddd;">
            OR enter custom value
            </p>
            
            <input
            type="number"
            id="K"
            placeholder="Custom Potassium value">
            <label>Temperature (°C)</label>
            <input type="number" id="temperature" required>

            <label>Humidity (%)</label>
            <input type="number" id="humidity" required>

            <label>pH Value</label>
            <input type="number" step="0.1" id="ph" required>

            <label>Rainfall (mm)</label>

            <input type="range"
            min="20"
            max="300"
            value="100"
            id="rainfall">

            <p id="rainfallValue">
                Value: 100 mm
            </p>

            <div class="btn-group">

                <button type="submit" class="predict-btn">
                    Predict Crop
                </button>

                <button type="reset" class="clear-btn">
                    Clear
                </button>

            </div>

        </form>

    </div>

    <!-- RIGHT -->

    <div class="result-section">

        <h2>Analysis Report</h2>

        <div id="predictionResult">

            <div class="empty-box">
                Prediction report will appear here
            </div>

        </div>

    </div>

</div>

<!-- FOOTER -->

<div class="footer">

    <p>© 2026 FarmNet | Smart Agriculture Platform</p>

    <p>Helping Farmers with Technology 🌱</p>

</div>

<script>

const rainfall = document.getElementById("rainfall");
const rainfallValue = document.getElementById("rainfallValue");

rainfall.addEventListener("input", function () {

    rainfallValue.innerText =
    "Value: " + rainfall.value + " mm";

});

document.getElementById("predictionForm")
.addEventListener("submit", async function (e) {

    e.preventDefault();

    const data = {
    
        N: parseFloat(document.getElementById("N").value),
        P: parseFloat(document.getElementById("P").value),
        K: parseFloat(document.getElementById("K").value),
    
        temperature: parseFloat(document.getElementById("temperature").value),
    
        humidity: parseFloat(document.getElementById("humidity").value),
    
        ph: parseFloat(document.getElementById("ph").value),
    
        rainfall: parseFloat(document.getElementById("rainfall").value)
    
    };

    try {

        const response = await fetch(
        "http://127.0.0.1:5000/predict", {

            method: "POST",

            headers: {
                "Content-Type": "application/json"
            },

            body: JSON.stringify(data)

        });

        const result = await response.json();

        document.getElementById("predictionResult").innerHTML = `

        <div class="result-card">

            <h1>🌱 ${result.predicted_crop}</h1>

            <div class="analysis">

                <p><strong>Nitrogen:</strong> ${data.N}</p>
                <p><strong>Phosphorus:</strong> ${data.P}</p>
                <p><strong>Potassium:</strong> ${data.K}</p>
                <p><strong>Temperature:</strong> ${data.temperature} °C</p>
                <p><strong>Humidity:</strong> ${data.humidity}%</p>
                <p><strong>pH:</strong> ${data.ph}</p>
                <p><strong>Rainfall:</strong> ${data.rainfall} mm</p>

                <hr>

                <p>✅ Soil nutrients are suitable for this crop.</p>

                <p>✅ Water level appears balanced.</p>

                <p>✅ Climate conditions support healthy growth.</p>

                <p>✅ Soil fertility looks appropriate.</p>

                <p>✅ Recommended for better farming yield.</p>

            </div>

        </div>
        `;

    }

    catch(error){

        document.getElementById("predictionResult").innerHTML = `

        <div class="result-card">

            <h2 style="color:red;">
                Prediction Failed
            </h2>

            <p>
                Please check Flask server connection.
            </p>

        </div>
        `;

        console.log(error);

    }

});

document.getElementById("N_select")
.addEventListener("change", function(){

    document.getElementById("N").value =
    this.value;

});

document.getElementById("P_select")
.addEventListener("change", function(){

    document.getElementById("P").value =
    this.value;

});

document.getElementById("K_select")
.addEventListener("change", function(){

    document.getElementById("K").value =
    this.value;

});
</script>

</body>
</html>